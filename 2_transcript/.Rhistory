full_curve_without_sampling_point <- full_curve %>% mutate(loop = loop + 35*(seconds >= 41552))  %>% mutate(Group = as.character(Group)) %>% mutate(Group = case_when(Group == "1" ~ "Reference log-phase sampled ", Group == "2" ~ "YGR067C_ko log-phase sampled ", Group == "3" ~ "Reference PDS-phase sampled ", Group == "4" ~ "YGR067C_ko PDS-phase sampled ", TRUE ~ Group))
average_loop_time <- full_curve_without_sampling_point %>% group_by(loop) %>% summarize(seconds = mean(seconds)) %>% as.data.frame()
median_curve <- full_curve_without_sampling_point %>% mutate(seconds = average_loop_time[loop,2]) %>% subset(!(loop %in% 34:36)) %>% group_by(Group, Replicate, seconds) %>% summarize( median_OD = median(OD560))
