median_curve <- full_curve_without_sampling_point %>% mutate(seconds = average_loop_time[loop,2]) %>% subset(!(loop %in% 34:36)) %>% group_by(Group, Replicate, seconds) %>% summarize( median_OD = median(OD560)) %>% filter(seconds/3600 >= 2)
for (i in 1:4) {
for (j in 1:3) {
median_curve[median_curve$Group == i &  median_curve$Replicate == j, ]$median_OD <- median_curve[median_curve$Group == i &  median_curve$Replicate == j, ]$median_OD - min(median_curve[median_curve$Group == i &  median_curve$Replicate == j, ]$median_OD)
}
}
