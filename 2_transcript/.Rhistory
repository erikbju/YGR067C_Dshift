growth_data <- read.csv("./Growth_curve/all_measurements.csv", sep = ",", quote="")
str_sub(growth_data$sample_phase, 1, 1) <- str_sub(growth_data$sample_phase, 1, 1) %>% str_to_upper()
colnames(growth_data) = c("dt", "test_name", "loop", "plate", "well", "OD560", "hours", "row", "column", "quadrant", "Strain", "Phase")
growth_data
ppath <- "/Users/cid/Documents/Erik_Genesis_Project/3.Transcriptomics/Analysis/EVE_exp/Growth_curve/Amiga"
full_curve <- growth_data %>% mutate(hours = hours * 3600) %>% rename(seconds = hours) %>% mutate(plate = as.numeric(plate)) %>% subset(!(loop %in% c(1,2) & seconds > 5000))
map_df <- full_curve %>% subset(loop == 1 & seconds < 36000) %>% dplyr::select(well, plate, Strain, Phase) %>% mutate(Replicate = floor(0.5+plate/2)) %>% mutate(plate = paste0("plate_", plate)) %>% mutate(Comments = paste0(Strain, "_", Phase))  %>% mutate(Group = 1 + (Strain == "YGR067C") + 2*(Phase == "Post-shift")) %>% mutate(Control = rep(0, length(Group))) %>% mutate(Strain = if_else(Strain == "WT", "BY4741", "YGR067C_ko")) %>% rename(Isolate = Strain) %>% rename(Plate_ID = plate) %>% rename(Well = well) %>% dplyr::select(-Phase) %>% relocate(Replicate, .after = Group)
plates <- list()
platemaps <- list()
for (i in 1:6) {
data_name <- paste0("plate_", i)
tmp <- reshape2::dcast(subset(full_curve, full_curve$plate == i), well ~ seconds, value.var ="OD560") %>% as.data.frame()
colnames(tmp)[1] <- "Time"
plates <- c(plates, list(tmp))
names(plates)[i] <- data_name
platemaps <- c(platemaps, list(map_df %>% subset(Plate_ID == data_name)))
names(platemaps)[i] <- data_name
}
