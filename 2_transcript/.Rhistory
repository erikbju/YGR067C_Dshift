read_all_data <- function(dir) {
files <- list.files(dir, pattern = "summary.txt", full.names = TRUE)
all_df <- lapply(files, read.table, header = TRUE, fill = F, sep = "\t",skip = 0)
return(all_df)
}
all_data <- read_all_data("/Users/cid/Documents/Erik_Genesis_Project/3.Transcriptomics/Analysis/EVE_exp/Growth_curve/Amiga/summary")
get_growthrates <- function(input, groupss, dix = T) {
out <- data.frame()
for (i in groupss) {
tmp <- input %>% subset(Group == i & diauxie == dix) %>% dplyr::select(Plate_ID, Isolate, gr)
colnames(tmp) <- c(tmp[1,1], "Isolate", "gr")
out <- rbind(out, tmp)
}
return(out)
}
