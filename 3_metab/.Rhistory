select_best_unique <- function(input) {
tmp <- input[!(input$INCHIKEY %in% input[duplicated(input$INCHIKEY),]$INCHIKEY),]
dup <- input[ (input$INCHIKEY %in% input[duplicated(input$INCHIKEY),]$INCHIKEY),]
unq <- dup$INCHIKEY %>% unique
for (i in unq) {
comp <- dup %>% subset(INCHIKEY == i)
out <- comp %>% subset(p == min(comp$p))
rbind(tmp, out)
}
return(tmp)
}
